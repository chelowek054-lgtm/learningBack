# learningBack — пример переменных окружения. Скопировать в .env (в git не коммитится).
# Секреты (CLAUDE_API_KEY) — ТОЛЬКО здесь, никогда в клиенте (инвариант №2).

APP_ENV=development

# Локально (host): localhost. Внутри docker-compose host = postgres (см. compose).
DATABASE_URL=postgresql+psycopg://praxis:praxis@localhost:5432/praxis

# Используется только backend'ом. В Ф0 не задействован.
CLAUDE_API_KEY=
